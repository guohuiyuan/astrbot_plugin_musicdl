{
  "downloadToLocal": {
    "description": "Download To Local",
    "hint": "对应 go-music-dl 的 downloadToLocal。关闭时音频仅作为 AstrBot 消息发送，发送后清理临时文件；开启时保留到 downloadDir。",
    "type": "bool",
    "default": false
  },
  "downloadDir": {
    "description": "Download Dir",
