{
  "downloadToLocal": {
    "description": "Download To Local",
    "hint": "对应 go-music-dl 的 downloadToLocal。关闭时音频仅作为 AstrBot 消息发送，发送后清理临时文件；开启时保留到 downloadDir。",
    "type": "bool",
    "default": false
  },
  "downloadDir": {
    "description": "Download Dir",
    "hint": "对应 go-music-dl 的 downloadDir。音频下载目录，默认 data/downloads。相对路径按 AstrBot 运行目录解析。",
    "type": "string",
    "default": "data/downloads"
  },
  "cliPageSize": {
    "description": "CLI Page Size",
    "hint": "对应 go-music-dl 的 cliPageSize。点歌搜索结果最多展示的歌曲数量。",
    "type": "int",
    "default": 50
  },
  "downloadConcurrency": {
    "description": "Download Concurrency",
    "hint": "对应 go-music-dl 的 downloadConcurrency。批量选择多首歌曲时的并发下载数，范围 1-5。",
    "type": "int",
    "default": 3
  },
  "sendMode": {
    "description": "Send Mode",
    "hint": "点歌下载后的发送方式：record 发送语音；file 发送群文件；both 同时发送语音和群文件。NapCat 与 AstrBot 不在同一文件系统时，file 会优先使用下载 URL 发送。",
    "type": "string",
    "default": "record",
    "options": [
      "record",
      "file",
      "both"
    ],
    "labels": [
      "语音 record",
      "群文件 file",
      "语音 + 群文件 both"
    ]
  },
  "forwardSongInfo": {
    "description": "Forward Song Info",
    "hint": "点歌下载后是否把歌曲详细信息通过合并转发发送出来.",
    "type": "bool",
    "default": true
  },
  "probeConcurrency": {
    "description": "Probe Concurrency",
    "hint": "搜索结果探测大小和码率时的并发数, 对应 go-music-dl UI 的探针行为.",
    "type": "int",
    "default": 5
  },
  "cookies": {
    "description": "Platform Cookies",
    "hint": "对应 go-music-dl 的 Cookie 管理。按平台填写 Cookie，留空表示不使用该平台 Cookie。",
